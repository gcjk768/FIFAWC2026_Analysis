# Copy this file to .env and fill in your values
# cp .env.example .env

PORT=3001
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b

# Telegram — get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_personal_telegram_user_id
TELEGRAM_CHANNEL_ID=-100your_supergroup_id
TELEGRAM_TOPIC_ID=your_topic_thread_id
DIGEST_TIME_SGT=08:00

# Obsidian — leave blank to use built-in vault/ directory
# Set to absolute path to use your own Obsidian vault
# Example: C:\Users\YourName\Documents\Obsidian\WC2026
OBSIDIAN_VAULT_PATH=
OBSIDIAN_WC_FOLDER=WC2026

# Optional — football-data.org free tier (for live match results)
FOOTBALL_API_KEY=

# Optional — Google Calendar integration
GOOGLE_CALENDAR_ID=primary

# Scheduler
OPENING_MATCH_DATE=2026-06-12T01:00:00+08:00
ALERT_TIMEZONE=Asia/Singapore

# Optional — for news in daily digest
NEWS_API_KEY=

# Chatbot
MAX_RESPONSE_TIME_MS=45000
